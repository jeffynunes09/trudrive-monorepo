PORT=3000
NODE_ENV=development

# MongoDB Atlas (produção)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/jndrive

# MongoDB local (docker-compose dev)
# MONGODB_URI=mongodb://root:root@localhost:27017/jndrive?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here

# ─── AWS S3 — Upload de fotos e documentos ───────────────────────────────────
# Região do bucket
AWS_REGION=us-east-1
# Credenciais IAM com permissão s3:PutObject no bucket
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# Nome do bucket S3 (deve existir e ter CORS configurado para PUT)
AWS_S3_BUCKET=jndrive-uploads
# ─────────────────────────────────────────────────────────────────────────────

# Push Notifications via Expo — sem env vars necessárias no backend.
# Os tokens são coletados pelos apps e salvos em user.pushToken.

# Google Maps
GOOGLE_API_KEY=your_google_maps_api_key

# Payment
MERCADO_PAGO_ACCESS_TOKEN=your_mercadopago_token

# OpenRouteService (self-hosted or public instance)
ORS_BASE_URL=https://api.openrouteservice.org
ORS_API_KEY=your_ors_api_key_here
