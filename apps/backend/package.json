{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "worker:notify": "ts-node src/workers/notifyDrivers.worker.ts",
    "worker:payment": "ts-node src/workers/payment.worker.ts",
    "seed": "ts-node src/seeds/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "build": "^0.1.4",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.21.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^8.0.0",
    "pnpm": "^10.30.3",
    "shared-config": "workspace:*",
    "shared-events": "workspace:*",
    "shared-types": "workspace:*",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.2",
    "socket.io-client": "^4.8.1",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
