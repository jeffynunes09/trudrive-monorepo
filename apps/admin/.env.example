# URL base pública do bucket S3 (ex: https://my-bucket.s3.sa-east-1.amazonaws.com)
# Usado para exibir documentos dos motoristas no painel admin
VITE_S3_BASE_URL=https://your-bucket.s3.your-region.amazonaws.com

# URL da API backend (opcional — por padrão usa proxy /api → localhost:3000)
VITE_API_URL=
